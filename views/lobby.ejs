<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=="undefined" ? title : "Jrob's game" %>
    </title>
    <link rel="stylesheet" href="/css/home.css">
    <script src="/js/lobby.js" defer></script>
</head>

<body>
    <%- include("partials/nav") %>

        <main>
            <%- include("partials/error") %>
                <h2>Lobby</h2>

                <section>
                    <h3>Games</h3>

                    <form method="post" action="/games">
                        <button type="submit">Create game</button>
                    </form>

                    <div id="games-list">
                        <p>Loading...</p>
                    </div>

                    <template id="game-card-template">
                        <div class="game-card">
                            <span data-game-id></span>
                            <span data-creator></span>
                            <span data-player-count></span>
                            <span data-status></span>
                            <form method="post">
                                <button>Join</button>
                            </form>
                        </div>
                    </template>

                </section>
        </main>
</body>

</html>